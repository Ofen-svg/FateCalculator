<Window x:Class="FateCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fate Calculator — Holy Grail War" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl x:Name="MainTabs">

            <!-- ===================== ВКЛАДКА: ПЕРСОНАЖИ ===================== -->
            <TabItem Header="Слуги и Мастера">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Список персонажей -->
                    <DockPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock DockPanel.Dock="Top" Text="Список персонажей" Style="{StaticResource HeaderText}"/>
                        <Button DockPanel.Dock="Top" Content="+ Новый персонаж" Margin="0,0,0,8" Click="NewCharacter_Click"/>
                        <ListBox x:Name="CharacterListBox" DisplayMemberPath="Name"
                                 SelectionChanged="CharacterListBox_SelectionChanged"/>
                    </DockPanel>

                    <!-- Карточка персонажа -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="CharacterDetailPanel" Margin="10">
                            <TextBlock Text="Выберите персонажа слева или создайте нового"
                                       Style="{StaticResource SubText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===================== ВКЛАДКА: БОИ ===================== -->
            <TabItem Header="Бои">
                <DockPanel Margin="10">
                    <Button DockPanel.Dock="Top" Content="+ Новый бой" HorizontalAlignment="Left" Margin="0,0,0,8"
                            Click="NewBattle_Click"/>
                    <TabControl x:Name="BattleTabs"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
